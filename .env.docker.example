# Copy to `.env` in the repo root (same folder as docker-compose.yml).
# docker compose reads this file automatically.

# ── Required for search / agents ─────────────────────────────
TINYFISH_API_KEY=

# ── Optional (same names as backend config) ─────────────────
EXA_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
BRIGHTDATA_PROXY_URL=
SUPERMEMORY_API_KEY=
ELEVENLABS_API_KEY=
DISCORD_WEBHOOK_URL=

# ── Browser → API wiring (critical) ─────────────────────────
# Local laptop only:
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3005,http://127.0.0.1:3005

# On a VPS with public IP 203.0.113.10 — use YOUR values, then:
#   docker compose build --no-cache web
#   docker compose up -d
# NEXT_PUBLIC_API_URL=http://203.0.113.10:8000
# CORS_ORIGINS=http://203.0.113.10:3005

# Optional port overrides (defaults 8000 / 3005)
# API_PUBLISH_PORT=8000
# WEB_PUBLISH_PORT=3005
