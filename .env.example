# TinyFish - Parallel pharmacy web scraping agents
TINYFISH_API_KEY=

# ElevenLabs - Vietnamese voice alerts
ELEVENLABS_API_KEY=

# Discord - Price drop notifications
DISCORD_WEBHOOK_URL=

# Exa - Semantic drug name search
EXA_API_KEY=

# OpenRouter - Drug name normalization + personalized insights (POST /api/insights)
OPENROUTER_API_KEY=

# Optional: OpenRouter model for /api/insights (default: qwen/qwen-2.5-72b-instruct)
INSIGHTS_MODEL=

# Supermemory - long-term memory (SDK also reads SUPERMEMORY_API_KEY)
SUPERMEMORY_API_KEY=

# CORS - comma-separated origins for the Next.js app (production deploy URL + localhost)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
