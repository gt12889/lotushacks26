# TinyFish - Parallel pharmacy web scraping agents
TINYFISH_API_KEY=

# ElevenLabs - Vietnamese voice alerts
ELEVENLABS_API_KEY=

# Discord - Price drop notifications
DISCORD_WEBHOOK_URL=

# Exa - Semantic drug name search
EXA_API_KEY=

# OpenAI - GPT-4o prescription OCR with function calling (Codex challenge)
OPENAI_API_KEY=

# OpenRouter - Drug name normalization (fallback for OCR if no OpenAI key)
OPENROUTER_API_KEY=

# BrightData - Proxy for anti-bot protection on pharmacy sites
BRIGHTDATA_PROXY_URL=

# Supermemory - long-term memory (SDK also reads SUPERMEMORY_API_KEY)
SUPERMEMORY_API_KEY=

# CORS - comma-separated origins for the Next.js app (production deploy URL + localhost)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
