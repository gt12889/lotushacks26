# Copy variable NAMES into Railway → each service → Variables.
# Values are examples; use your real secrets in the dashboard (never commit secrets).
#
# Without GitHub: use Dockerfiles in `backend/` + `frontend/` with Railway CLI
# (`railway up` from each folder after `railway link`) or “Deploy Docker image”
# from Docker Hub / GHCR. See docs/README.md → “Deploy on Railway”.

# ─── Backend service (root directory: backend) ─────────────────────────────
# Required for live search / agents (add what you use locally from .env)
TINYFISH_API_KEY=
EXA_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
BRIGHTDATA_PROXY_URL=

# Optional
ELEVENLABS_API_KEY=
DISCORD_WEBHOOK_URL=
SUPERMEMORY_API_KEY=

# MUST include your Railway frontend URL(s) so the browser can call the API.
# Comma-separated, no spaces (or minimal). Example:
# CORS_ORIGINS=https://megladon-frontend-production.up.railway.app,http://localhost:3005
CORS_ORIGINS=

# SQLite path (default is fine; data is ephemeral unless you add a Railway volume)
# DATABASE_URL=sqlite:///./megladon_md.db

# ─── Frontend service (root directory: frontend) ───────────────────────────
# Public URL of the backend (from Railway → backend service → Settings → Networking → Public URL)
# No trailing slash. Example: https://megladon-api-production.up.railway.app
NEXT_PUBLIC_API_URL=
